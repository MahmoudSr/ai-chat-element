# Dependencies
node_modules

# Build output (published to npm, never committed to git)
dist

# Static site build for GitHub Pages (generated by `npm run build:site`;
# the deploy workflow builds it fresh, so it never belongs in git)
dist-site

# Test artifacts
coverage
test-results
playwright-report

# Secrets & local env — NEVER commit these
.env
.env.*
*.local

# Logs & caches
*.log
npm-debug.log*
.vite
.cache

# Local project notes (personal machine/setup details — keep out of the repo)
CLAUDE.md

# OS / editor junk
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
